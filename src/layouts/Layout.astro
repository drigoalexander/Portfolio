---
import "@fontsource/ubuntu/400.css";
import "@fontsource/ubuntu/500.css";
import "@fontsource/ubuntu/700.css";
import "@fontsource/ubuntu/400-italic.css";
import "@fontsource/ubuntu/700-italic.css";
import "../styles/global.css";
import { site } from "../content/story";

interface Props {
  title?: string;
  description?: string;
  /** path under /public — 1200×630 */
  ogImage?: string;
}
const {
  title = `${site.name} — ${site.role}`,
  description = "Drigo Alexander — software engineer. A story about growing: from a small room in Jakarta to shipping for the wider world.",
  ogImage = "/og.jpg",
} = Astro.props;

// absolute URLs need `site` in astro.config.mjs — swap the placeholder for
// the real domain at launch and everything below follows automatically
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
const ogImageAlt = "A hand-drawn apple tree in a painted field — Drigo Alexander's story of growth";

const realSocials = site.socials.filter((s) => s.href.startsWith("http"));
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: site.name,
    jobTitle: site.role,
    email: `mailto:${site.email}`,
    url: canonical?.origin,
    image: ogImageUrl,
    sameAs: realSocials.map((s) => s.href),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: canonical?.origin,
    description,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    {canonical && <link rel="canonical" href={canonical.href} />}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#14110b" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="preload"
      href="/fonts/GeistPixel-Square.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical.href} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <script>
      import { initGsap } from "../lib/gsap";
      initGsap();
    </script>
  </body>
</html>
