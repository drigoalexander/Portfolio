---
import { chapters, site } from "../../content/story";

const c = chapters[7]!;
---

<!-- the epilogue stands beside the finished tree, never behind it -->
<footer
  id={c.id}
  data-chapter="7"
  aria-labelledby={`${c.id}-title`}
  class="relative flex min-h-svh items-center py-[16vh] pr-6 pl-10 text-sand-ink md:pl-[8vw]"
>
  <div class="copy-scrim relative z-10 max-w-md space-y-7" style={`--scrim: ${c.ground}`}>
    <h2
      id={`${c.id}-title`}
      data-anim="split"
      data-anim-duration="1.4"
      class="font-display text-4xl leading-[0.92] text-sand-ink uppercase md:text-5xl xl:text-6xl"
    >
      {c.title}
    </h2>

    <p
      data-anim="split"
      data-anim-delay="0.25"
      class="max-w-sm font-sans text-xs leading-loose tracking-widest text-sand-ink-soft uppercase md:text-sm"
    >
      {c.body}
    </p>

    <a
      href={`mailto:${site.email}`}
      data-anim="reveal"
      data-anim-delay="0.4"
      class="inline-block font-sans text-2xl text-sand-ink italic underline decoration-sand-ink/30 underline-offset-8 transition-colors hover:decoration-sand-ink focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-sand-ink md:text-3xl"
    >
      {site.email}
    </a>

    <!-- social links hidden for now (per Drigo) — data stays in story.ts;
         restore this nav when the profiles are ready to show -->

    <p class="pt-4 font-sans text-[9px] tracking-[0.35em] text-sand-ink-soft/70 uppercase">
      © 2026 {site.name} — {c.meta}
    </p>
  </div>
</footer>
