---
import { chapters } from "../../content/story";

const c = chapters[4]!;
---

<!-- the pivot: the biggest words of the story, low-left, while the bold
     branch sweeps through the empty upper frame -->
<section
  id={c.id}
  data-chapter="4"
  aria-labelledby={`${c.id}-title`}
  class="relative flex min-h-svh items-end py-[18vh] pr-6 pb-[22vh] pl-10 md:pl-[9vw]"
>
  <div class="copy-scrim relative z-10 max-w-xl space-y-6" style={`--scrim: ${c.ground}`}>
    <h2
      id={`${c.id}-title`}
      data-anim="split"
      data-anim-duration="1.4"
      class="font-display text-5xl leading-[0.9] text-ink uppercase md:text-7xl xl:text-8xl"
    >
      {c.title}
    </h2>

    <p
      data-anim="split"
      data-anim-delay="0.25"
      class="max-w-sm font-sans text-xs leading-loose tracking-[0.08em] text-ink-soft/85 uppercase md:text-sm"
    >
      {c.body}
    </p>

    <p
      data-anim="reveal"
      data-anim-start="top 96%"
      class="font-sans text-[10px] tracking-[0.35em] text-ink-soft/70 uppercase"
    >
      — {c.meta}
    </p>
  </div>
</section>
